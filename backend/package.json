{
  "name": "hy-agi-backend",
  "version": "1.0.0",
  "description": "Multi-agent AI security operations platform backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && cp -r ../frontend dist/ || xcopy /E /I ..\\frontend dist\\frontend",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "migrate": "ts-node src/database/migrate.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "security",
    "pentest",
    "multi-agent",
    "orchestration"
  ],
  "author": "BIT-CIS Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "redis": "^4.6.13",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pgvector": "^0.1.8",
    "neo4j-driver": "^5.17.0",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "prom-client": "^15.1.0",
    "compromise": "^14.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.17",
    "@types/jest": "^29.5.12",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.5",
    "@types/ws": "^8.5.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
