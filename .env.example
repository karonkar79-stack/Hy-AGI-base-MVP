# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://hyagi:hyagi_password@localhost:5432/hyagi
POSTGRES_USER=hyagi
POSTGRES_PASSWORD=hyagi_password
POSTGRES_DB=hyagi

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Neo4j Configuration
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hyagi_neo4j_password

# Security
JWT_SECRET=generate_with_openssl_rand_hex_32_change_in_production
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cost Management
DEFAULT_BUDGET_PER_WORKFLOW=5.0
MAX_BUDGET_PER_WORKFLOW=100.0
COST_ALERT_THRESHOLD=0.8

# Monitoring
METRICS_ENABLED=true
LOG_LEVEL=info
