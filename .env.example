# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://hyagi:hyagi_password@localhost:5432/hyagi
POSTGRES_USER=hyagi
POSTGRES_PASSWORD=hyagi_password
POSTGRES_DB=hyagi

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Neo4j Configuration
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hyagi_neo4j_password

# Security
JWT_SECRET=generate_with_openssl_rand_hex_32_change_in_production
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cost Management
DEFAULT_BUDGET_PER_WORKFLOW=5.0
MAX_BUDGET_PER_WORKFLOW=100.0
COST_ALERT_THRESHOLD=0.8

# Monitoring
METRICS_ENABLED=true
LOG_LEVEL=info

# Lark / Feishu Knowledge Base (Lark International)
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_lark_app_secret_here
LARK_DOMAIN=https://open.larksuite.com

# AWS Bedrock (Claude via Bedrock API key / bearer token)
# When AWS_BEARER_TOKEN_BEDROCK is set, agents call Claude through Bedrock
# instead of the Anthropic API, and ANTHROPIC_API_KEY becomes optional.
# In us-east-1 use the US cross-region inference profile (us.anthropic.*).
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Bedrock embeddings for the pgvector knowledge base (Amazon Titan).
# Titan V2 native dim is 1024 — keep KB_EMBED_DIM in sync with the migration.
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
KB_EMBED_DIM=1024
